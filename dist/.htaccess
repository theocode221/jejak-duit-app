# SPA fallback for Apache (cPanel). Ensures React Router URLs work on refresh.
# If the app lives in a subfolder (e.g. public_html/bajet/), set RewriteBase to that path.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
